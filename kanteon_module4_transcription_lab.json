{
  "module": "transcription_lab",
  "version": "1.0",
  "description": "Student hears a target pattern and rebuilds it in a step sequencer. A/B toggle compares target to student version. Submit when ready. Two track types: drum (kick/snare/hi-hat) and melodic (fixed pitch set tied to real songs).",
  "ui_notes": {
    "grid": "16 steps per bar. Each step is a toggle button.",
    "ab_compare": "Toggle between target audio and student's built version at any time.",
    "step_preview": "Tap individual step to hear that note/hit in isolation.",
    "metronome": "Optional. Click track at session BPM.",
    "submit": "Forces commitment — no changing after submit. Correct steps highlighted after submission.",
    "scoring": "Per-step accuracy. Partial credit. XP scales with accuracy percentage."
  },
  "audio_generation": {
    "kick": "Sine oscillator sweep 150Hz→50Hz over 80ms. Add slight distortion.",
    "snare": "White noise burst 60ms + sine body at 200Hz. Mix 70/30 noise/tone.",
    "hihat_closed": "High-pass filtered white noise above 8kHz. Decay 30ms.",
    "hihat_open": "Same as closed but decay 180ms.",
    "melodic": "Triangle or sine oscillator at specified Hz. Add slight overdrive for rock riffs. Decay 300ms or until next step.",
    "chorus_effect": "Two detuned oscillators 8 cents apart + slight delay 20ms. Used for Come As You Are."
  },
